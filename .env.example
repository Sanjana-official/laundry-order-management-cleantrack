# ─────────────────────────────────────────────
# CleanTrack — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/cleantrack
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/cleantrack
MONGODB_URI=mongodb://localhost:27017/cleantrack

# JWT secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# JWT expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Node environment: development | production
NODE_ENV=development

# CORS origin — your frontend URL
# Local dev:  http://localhost:5000
# Production: https://your-app.onrender.com
CLIENT_ORIGIN=http://localhost:5000
